# Dev: leave unset to use Vite proxy → same origin, no CORS issues.
# Or set explicitly, e.g. http://localhost:5000 (must match server PORT + CORS CLIENT_URL).
# VITE_API_URL=http://localhost:5000

# When VITE_API_URL is unset in dev, Vite proxies /api here (match docuwise-ai-server PORT).
VITE_DEV_API_PROXY_TARGET=http://localhost:5000

